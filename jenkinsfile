pipeline {
    agent any

    tools {
        nodejs 'node18'
    }

    environment {
        DOCKER_IMAGE = 'simplybyte-frontend'
        CONTAINER_NAME = 'simplybyte-frontend-container'
    }

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['testing', 'prod'], description: 'environment')
    }

    stages {

        stage('Git Clone') {
            steps {
                git branch: 'main',
                    credentialsId: 'github_simplybyte_credentials',
                    url: 'https://github.com/simplybyte1266/simplybyte-frontend.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Run Tests') {
            when {
                expression { params.ENVIRONMENT == 'testing' }
            }
            steps {
                sh 'npm test -- --watchAll=false'
            }
        }

        stage('Build Frontend') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Docker Build Image') {
            steps {
                sh 'docker build -t $DOCKER_IMAGE:$BUILD_NUMBER .'
            }
        }

        stage('Remove Old Container') {
            steps {
                sh 'docker rm -f $CONTAINER_NAME || true'
            }
        }

        stage('Run New Container') {
            steps {
                sh '''
                docker run -d -p 8091:80 \
                --name=$CONTAINER_NAME \
                $DOCKER_IMAGE:$BUILD_NUMBER
                '''
            }
        }
    }
}